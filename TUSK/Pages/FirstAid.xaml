<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TUSK.FirstAid"
             Title="FirstAid">
    <VerticalStackLayout>
        <ImageButton Aspect="AspectFit" Source="back_button.png"
        Clicked="OnBackClicked" HorizontalOptions="Start" WidthRequest="100"
        HeightRequest="60"/>
        <Button 
            Text="Home"  
            Clicked="OnHomeClicked"/>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>