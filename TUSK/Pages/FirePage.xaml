<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TUSK.FirePage"
             Title="FirePage">
    <VerticalStackLayout Padding="20" Spacing="5" BackgroundColor="#E0E0E0">
        <ImageButton Aspect="AspectFit" Source="back_button.png"
        Clicked="OnBackClicked" HorizontalOptions="Start" WidthRequest="100"
        HeightRequest="60"/>
        <Button 
        Text="Home"  
        Clicked="OnHomeClicked"/>
        
        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
          ColumnDefinitions="*"
          Padding="5"
          RowSpacing="10"
          ColumnSpacing="20"
          BackgroundColor="{StaticResource AppBackground}">

            <Label>Text here, buttons and images</Label>
            <Grid><!-- survival tips, dropdown menu with a arrow stacked on top of the 
                label button with pseudo animation by rotating 180/horizontal flip-->
                </Grid>
         
        </Grid>
    </VerticalStackLayout>
</ContentPage>