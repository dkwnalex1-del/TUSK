<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TUSK.CompassPage"
             >
    <VerticalStackLayout Padding="20" Spacing="5" BackgroundColor="#E0E0E0">

            <ImageButton Aspect="AspectFit" Source="back_button.png"
            Clicked="OnBackClicked" HorizontalOptions="Start" 
            WidthRequest="80"
            MaximumWidthRequest="120"
            HeightRequest="60"
            MaximumHeightRequest="85"/>
        
        <Label 
            Text="COMPASS"
            FontSize="24"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            TextColor="#000000"/>
        <Grid 
            HorizontalOptions="Center" 
            VerticalOptions="Center"
            MaximumWidthRequest="350"
            MaximumHeightRequest="350">

            <!-- Rotating dial -->
            <Image 
            x:Name="DialImage"
            Source="compass_dial.png"
            Aspect="AspectFit"/>

            <!-- Static needle -->
            <Image 
            Source="compass_needle.png"
            Aspect="AspectFit"/>

        </Grid>
        <Label x:Name="DirectionLabel" FontSize="24" TextColor="#000000" HorizontalTextAlignment="Center"/>
        <Label x:Name="HeadingLabel" FontSize="24" TextColor="#000000" HorizontalTextAlignment="Center"/>

        </VerticalStackLayout>
</ContentPage>