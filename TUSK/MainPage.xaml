<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TUSK.MainPage"
             Title="MainPage"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView BackgroundColor="{StaticResource AppBackground}">
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Button Text="COMPASS" Clicked="OnCompassClicked" FontSize="24"/>
            <Button Text="FOOD LIST" FontSize="24"/>
            <Button Text="SURVIVAL GUIDE" FontSize="24"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
